# ============================================================================
# REQUIRED: Claude API Configuration
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ============================================================================
# Meta-Specific Configuration (Optional - only needed at Meta)
# ============================================================================
# Uncomment these if you're running inside Meta's network
# ANTHROPIC_BASE_URL=http://plugboard.x2p.facebook.net
# HTTP_PROXY=http://localhost:10054
# HTTPS_PROXY=http://localhost:10054
# X2P_AGENT_PROXY_ADDRESS=localhost:10054
# ANTHROPIC_META_CAT_TOKEN=your_cat_token_here
# CPE_RUST_X2P_SUPPORTS_VPNLESS=1
# X2P_SUPPORTS_VPNLESS=1

# ============================================================================
# Claude Code Binary Path Configuration (Optional)
# ============================================================================
# Override the default Claude Code binary paths if needed
# HIVEMIND_CLAUDE_CMD=/path/to/claude                                    # Full override
# HIVEMIND_CLAUDE_NATIVE_BIN=/usr/local/bin/claude_code/native/claude    # Meta-specific native binary
# HIVEMIND_CLAUDE_NODE=/usr/local/bin/claude_code/node                   # Meta-specific node path
# HIVEMIND_CLAUDE_CLI=/usr/local/bin/claude_code/node_modules/@anthropic-ai/claude-code/cli.js

# Database - PostgreSQL (optional, defaults to SQLite)
# POSTGRES_PASSWORD=your-secure-password-here
# DB_URL=postgresql://hivemind:your-secure-password-here@postgres:5432/hivemind

# ============================================================================
# Application Configuration
# ============================================================================
NODE_ENV=production
PORT=3100
HIVEMIND_HOME=/app/data

# Agent Configuration
HIVEMIND_MAX_AGENTS=2                 # Max concurrent agents (license-dependent)
HIVEMIND_HEARTBEAT_SEC=60             # Agent heartbeat interval
HIVEMIND_HEALTH_CHECK_SEC=30          # How often to check agent health (default: 30s)
HIVEMIND_CHECKPOINT_TURNS=5           # Save checkpoint every N turns (default: 5)
HIVEMIND_SLACK_WEBHOOK=               # Optional: Slack webhook URL for crash alerts
