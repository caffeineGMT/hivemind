{
  "name": "hivemind",
  "version": "0.1.0",
  "description": "Autonomous AI company orchestrator — spawn a team of Claude agents via tmux",
  "type": "module",
  "bin": {
    "hivemind": "./bin/hivemind.js"
  },
  "scripts": {
    "start": "node bin/hivemind.js",
    "build": "cd ui && npm run build",
    "test:e2e": "cd ui && npx playwright test",
    "migrate": "node src/migration-runner.js up",
    "migrate:rollback": "node src/migration-runner.js down",
    "migrate:status": "node src/migration-runner.js status"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "sanitize-html": "^2.17.2",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
